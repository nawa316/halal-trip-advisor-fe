{
  "name": "next-js-boilerplate",
  "author": "Ixartz (https://github.com/ixartz)",
  "scripts": {
    "dev:spotlight": "npx @spotlightjs/spotlight",
    "dev:next": "next dev",
    "dev": "npm run dev:next",
    "build:next": "next build",
    "build-local": "next build",
    "build": "next build",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true npm run build",
    "clean": "rimraf .next out coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.mts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@arcjet/next": "^1.6.1",
    "@clerk/localizations": "^4.12.0",
    "@clerk/nextjs": "^7.5.11",
    "@hookform/resolvers": "^5.4.0",
    "@logtape/logtape": "^2.2.2",
    "@sentry/nextjs": "^10.62.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "aos": "^2.3.4",
    "drizzle-orm": "^0.45.1",
    "mapbox-gl": "^3.25.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-hot-toast": "^2.6.0",
    "react-map-gl": "^7.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite-socket": "^0.2.6",
    "@faker-js/faker": "^10.5.0",
    "@lingual/i18n-check": "^0.9.3",
    "@next/bundle-analyzer": "^16.2.9",
    "@spotlightjs/spotlight": "^4.11.7",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@swc/helpers": "^0.5.23",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/aos": "^3.0.8",
    "@types/mapbox-gl": "^3.4.0",
    "@types/node": "^25.9.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "knip": "^6.23.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.5",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.1.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
